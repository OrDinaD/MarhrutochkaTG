# ===================================
# MarhrutochkaTG Bot Configuration
# ===================================

# 🤖 Основные настройки бота
BOT_TOKEN=your_telegram_bot_token_here

# 👑 Административный доступ  
ADMIN_TELEGRAM_ID=your_admin_user_id
AUTH_TOKEN=your_auth_token_here

# 🚀 Railway настройки (автоматически устанавливаются при деплое)
# RAILWAY_SERVICE_NAME=marha-bot
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_ID=your_project_id

# 🔄 Для команды /reload (перезагрузка бота через Telegram)
# RAILWAY_TOKEN=your_railway_api_token_here
# RAILWAY_SERVICE_ID=your_service_id_here
# Инструкция: docs/RAILWAY_RELOAD.md

# 📊 Настройки логирования
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# 🛠️ Настройки для разработки
DEVELOPMENT_MODE=true
DEBUG=false

# 🔧 Опциональные настройки
CRASH_REPORTING=true
AUTO_RECOVERY=true
LOG_TO_FILE=true

# 📝 Логирование в Telegram (опционально)
LOG_BOT_TOKEN=optional_log_bot_token
LOG_CHAT_ID=optional_log_chat_id

# ⏰ Настройки мониторинга
MONITORING_INTERVAL=300
ALERT_THRESHOLD_SEATS=5

# 🔍 Настройки парсера
PARSER_TIMEOUT=30
PARSER_DELAY=1

# 🌐 Настройки веб-авторизации
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
