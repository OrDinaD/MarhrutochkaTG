# ===================================
# MarhrutochkaTG Bot Configuration
# ===================================

# 🤖 Основные настройки бота
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 👑 Административный доступ  
ADMIN_TELEGRAM_ID=your_admin_user_id

# 📝 Логирование в Telegram (опционально)
LOG_BOT_TOKEN=optional_log_bot_token
LOG_CHAT_ID=optional_log_chat_id

# ⏰ Настройки мониторинга
MONITORING_INTERVAL=300
ALERT_THRESHOLD_SEATS=5

# 🔍 Настройки парсера
PARSER_TIMEOUT=30
PARSER_DELAY=1

# 🌐 Настройки веб-авторизации
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# 🐛 Режим отладки
DEBUG=false
LOG_BOT_TOKEN=
LOG_CHAT_ID=
