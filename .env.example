# MarhrutochkaTG Bot Configuration
#
# Copy this file to .env and fill private values locally.
# Never commit real bot, auth, Railway, or logging tokens.

# Required private values:
# - TELEGRAM_BOT_TOKEN
# - ADMIN_TELEGRAM_ID
# - AUTH_TOKEN, optional
# - RAILWAY_TOKEN, optional for /reload
# - RAILWAY_SERVICE_ID, optional for /reload
# - LOG_BOT_TOKEN, optional
# - LOG_CHAT_ID, optional

# Railway settings, usually configured by Railway automatically:
# RAILWAY_SERVICE_NAME
# RAILWAY_ENVIRONMENT
# RAILWAY_PROJECT_ID

# Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# Development
DEVELOPMENT_MODE=true
DEBUG=false

# Optional runtime settings
CRASH_REPORTING=true
AUTO_RECOVERY=true
LOG_TO_FILE=true

# Monitoring
MONITORING_INTERVAL=300
ALERT_THRESHOLD_SEATS=5

# Parser
PARSER_TIMEOUT=30
PARSER_DELAY=1

# Web authorization
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
